{
  "name": "osf-workspace",
  "version": "1.1.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "nx": "nx",
    "serve:osf-ui": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true nx run osf-ui:serve",
    "graph": "nx graph",
    "test": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true nx run-many -t test",
    "test:osf-ui": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true nx test osf-ui",
    "test:mqtt-client": "nx test mqtt-client",
    "test:coverage": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true nx test osf-ui --coverage",
    "test:coverage:check": "BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true nx test osf-ui --coverage --coverageThreshold",
    "update-version": "node scripts/update-ui-version.js",
    "version:bump": "node scripts/version-bump.js",
    "export-use-case-svgs": "node scripts/export-use-case-svgs.js",
    "export-dsp-architecture-svgs": "node scripts/export-dsp-architecture-svgs.js",
    "build": "npm run update-version && nx build mqtt-client",
    "build:fixtures": "python scripts/build_order_fixtures.py",
    "build:github-pages": "npm run update-version && BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true nx build osf-ui --configuration=github-pages",
    "serve:local": "node scripts/serve-local.js",
    "docker:osf-ui": "node scripts/build-osf-ui-docker.js",
    "docker:osf-ui:arm": "node scripts/build-osf-ui-docker.js arm",
    "docker:osf-ui:armv7": "node scripts/build-osf-ui-docker.js armv7",
    "docker:osf-ui:local": "node scripts/build-osf-ui-docker.js amd64",
    "docker:osf-ui:deploy": "node scripts/deploy-osf-ui-to-rpi.js",
    "version": "npm run build && git add -A",
    "postversion": "git push && git push --tags",
    "version:patch": "npm version patch -m 'chore(release): %s'",
    "version:minor": "npm version minor -m 'feat(release): %s'",
    "version:major": "npm version major -m 'feat(release): %s [BREAKING]'",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "open:verdrahtung-multisensor": "open docs/05-hardware/arduino-r4-multisensor.md"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~18.2.0",
    "@angular-devkit/core": "~18.2.0",
    "@angular-devkit/schematics": "~18.2.0",
    "@angular/cli": "~18.2.0",
    "@angular/compiler-cli": "~18.2.0",
    "@angular/language-service": "~18.2.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "19.8.5",
    "@nx/devkit": "19.8.5",
    "@nx/eslint": "19.8.5",
    "@nx/eslint-plugin": "19.8.5",
    "@nx/jest": "19.8.5",
    "@nx/js": "19.8.5",
    "@nx/web": "19.8.5",
    "@nx/workspace": "19.8.5",
    "@schematics/angular": "~18.2.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.24",
    "@swc/helpers": "~0.5.21",
    "@types/highlight.js": "^9.12.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.16.5",
    "@typescript-eslint/utils": "^8.0.0",
    "angular-eslint": "^18.3.0",
    "baseline-browser-mapping": "^2.10.18",
    "conventional-changelog-cli": "^4.1.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "~14.1.0",
    "mqtt": "^5.14.1",
    "nx": "19.8.5",
    "prettier": "^2.6.2",
    "puppeteer": "^23.11.1",
    "serve-handler": "^6.1.6",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.6.2",
    "tsx": "^4.15.0",
    "typescript": "5.5.4",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@angular/animations": "~18.2.0",
    "@angular/common": "~18.2.0",
    "@angular/compiler": "~18.2.0",
    "@angular/core": "~18.2.0",
    "@angular/forms": "~18.2.0",
    "@angular/localize": "~18.2.0",
    "@angular/platform-browser": "~18.2.0",
    "@angular/platform-browser-dynamic": "~18.2.0",
    "@angular/router": "~18.2.0",
    "ajv": "^8.17.1",
    "highlight.js": "^11.11.1",
    "rxjs": "^7.8.1",
    "zone.js": "~0.14.3"
  }
}
