{
  "replay_station": {
    "session_directory": "data/osf-data/sessions",
    "mqtt_broker": {
      "host": "localhost",
      "port": 1883,
      "qos": 1,
      "timeout": 5
    },
    "replay": {
      "default_speed": 1.0,
      "auto_play": false,
      "loop_playback": false
    }
  },
  "session_recorder": {
    "session_directory": "data/osf-data/sessions",
    "mqtt_broker": {
      "host": "192.168.0.100",
      "port": 1883,
      "qos": 1,
      "timeout": 5,
      "username": "default",
      "password": "default"
    },
    "recording": {
      "auto_save": true,
      "save_interval": 300,
      "max_file_size": 100,
      "recording_exclusion_preset": "no_cam"
    }
  },
  "object_detection": {
    "capture_settings": {
      "base_directory": "data/osf-data/sessions/object-detection",
      "mqtt_broker": {
        "host": "192.168.0.100",
        "port": 1883,
        "qos": 1,
        "timeout": 5,
        "username": "default",
        "password": "default"
      },
      "capture": {
        "topic_filters": [
          "#"
        ],
        "save_full_events": false,
        "video_filename": "video.mp4"
      }
    }
  },
  "template_analysis": {
    "show_payload_preview": true,
    "max_payload_length": 200
  },
  "test": {
    "value": "test_value"
  }
