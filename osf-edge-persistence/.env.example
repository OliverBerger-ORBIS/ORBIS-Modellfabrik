# Profile selector template.
# Recommended:
# - LIVE mode (default): use values from env.live
# - REPLAY mode (tests): use values from env.replay
#
# Typical workflow:
#   cp env.live .env
#   # or
#   cp env.replay .env
#
# This file remains as a neutral fallback template.
POSTGRES_DB=osf
POSTGRES_USER=osf
POSTGRES_PASSWORD=osf_dev
POSTGRES_EXTERNAL_PORT=5432

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_EXTERNAL_PORT=3000

MQTT_HOST=192.168.0.100
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=osf-persistence-edge

PERSISTENCE_MODE=live
RAW_RETENTION_DAYS=14
SENSOR_INTERVAL_SECONDS=3600
ENABLE_RAW_MESSAGES=true
ENABLE_CAMERA_TOPIC=false
LOG_LEVEL=info
